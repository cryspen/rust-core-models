# Aeneas-extracted output for the two test crates (regenerated each
# build). The hand-written stubs (`FunsExternal.lean`,
# `TypesExternal.lean`) and the entry-point modules (`ClientTest.lean`,
# `RustLeanTests.lean`) stay tracked.
tests/client_test/lean/ClientTest/Funs.lean
tests/client_test/lean/ClientTest/Types.lean
tests/rust_lean_equiv_test/lean/RustLeanTests/Funs.lean
tests/rust_lean_equiv_test/lean/RustLeanTests/Types.lean
# `LeanTests.lean` is generated by `gen_lean_tests.py` from the
# `#[rust_lean_test]` attributes in `source/src/**/*.rs`.
tests/rust_lean_equiv_test/lean/RustLeanTests/LeanTests.lean
